# Database (SQLite default for DSMLP, or PostgreSQL for other environments)
DATABASE_URL=sqlite+aiosqlite:////data/passports.db

# JWT signing secret (generate a 32+ byte key)
JWT_SECRET=replace-with-a-random-64-char-hex-string

# Frontend API base URL (used at build time, defaults to /api)
VITE_API_URL=/api
